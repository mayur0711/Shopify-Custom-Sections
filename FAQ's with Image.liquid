<style>

.faq-image-left,
.faq-image-left + .faq-content-right {
  width: 100%;
  max-width: 50%;
}

.faq-content-right {
  width: 100%;
  max-width: 100%;
}

.faq-image-left img {
  width: 100%;
  height: 100%;
  border-radius: 12px;
}    

.custom-faq-section .section_heading.section_heading_design {
  margin: 0 auto 30px;
  width: fit-content;
  font-size: 35px;
}

.faqs_page_width {
  {% comment %} max-width: calc({{ section.settings.faqs_page_width }}px + 10rem); {% endcomment %}
  max-width: {{ section.settings.faqs_page_width }}px;
  margin: auto;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 40px;
}

.faq-content-right .faq_div {
  background: linear-gradient(180deg, #f5f5f5 0%, #FFFFFF 100%);
  box-shadow: 0px 2px 16px rgba(0, 0, 0, 0.05);
  border-radius: 12px;
  padding: 35px;
}


.shopify_explorer_faq__item {
  background: {{ section.settings.faqs_background }};
  {% comment %} border-radius: 12px; {% endcomment %}
}

.shopify_explorer_faq__item:not(:last-child) {
  border-bottom: 1px solid #F7B51130;
}

{% comment %} .shopify_explorer_faq__item:not(:last-child) {
  margin-bottom: 20px;
} {% endcomment %}

.shopify_explorer_faq__question {
  margin: 0;
  display: flex;
  align-items: center;
  {% comment %} justify-content: space-between; {% endcomment %}
  gap: 20px;
  {% comment %} padding: 30px 0; {% endcomment %}
  padding: 20px 0;
  cursor: pointer;
  font-size: 18px;
  font-weight: 700;
  letter-spacing: 0;
  transition: padding 0.4s ease;
}

.shopify_explorer_faq__question.open {
  padding-bottom: 10px;
}

.shopify_explorer_faq__question svg {
  min-width: 30px;
}

{% comment %} .shopify_explorer_faq__question span {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 20px;
} {% endcomment %}

.shopify_explorer_faq__question .faq_plus_icon {
  transition: 0.4s ease-in-out;
  width: 20px !important;
  height: 20px !important;
}

{% comment %} .shopify_explorer_faq__question.open {
  padding: 30px 0 10px;
} {% endcomment %}

.shopify_explorer_faq__question.open .faq_plus_icon {
  transform: rotate(135deg);
  transition: 0.4s ease-in-out;
}

.shopify_explorer_faq__answer {
  {% comment %} padding: 0 30px 30px 50px; {% endcomment %}
  padding: 0 20px 20px 50px;
  font-size: 16px;
  line-height: 26px;
  letter-spacing: 0;
}

.shopify_explorer_faq__item .shopify_explorer_faq__question {
  color: {{ section.settings.faqs_text_color }};
}

.shopify_explorer_faq__item .shopify_explorer_faq__answer p,
.shopify_explorer_faq__item .shopify_explorer_faq__answer a {
  color: #838282;
}
  
.shopify_explorer_faq__item > .shopify_explorer_faq__answer {
  display: none;
}

.shopify_explorer_faq__item:first-child .shopify_explorer_faq__question {
  padding-top: 0 !important;
}

.shopify_explorer_faq__item:last-child .shopify_explorer_faq__question {
  padding-bottom: 0 !important;
}

.shopify_explorer_faq__item:last-child .shopify_explorer_faq__question.open {
  padding-bottom: 10px !important;
}

.shopify_explorer_faq__item:last-child .shopify_explorer_faq__answer {
  padding-bottom: 0px !important;
}

@media(max-width:1599px) {
  .faqs_page_width {
    gap: 30px;
  }

  .custom-faq-section .section_heading.section_heading_design {
    font-size: 26px;
    margin-bottom: 20px;
  }

  .faq-content-right .faq_div {
    padding: 25px;
  }

  .shopify_explorer_faq__question svg {
    min-width: 25px;
    width: 25px;
    height: 25px;
  }

  .shopify_explorer_faq__question {
    font-size: 15px;
    padding: 20px 0;
  }

  .shopify_explorer_faq__answer {
    font-size: 14px;
    padding: 0 20px 20px 45px;
  }
}

@media(max-width:1319px) {
  .custom-faq-section {
    padding-block: 40px !important;
  }
}

@media(max-width:1023px) {
  .faqs_page_width {
    flex-direction: column-reverse;
  }

  .faq-image-left,
  .faq-image-left + .faq-content-right {
    width: 100%;
    max-width: 100%;
  }

  .faq-content-right .faq_div {
    padding: 20px;
  }
}
  
</style>

{% schema %}
  {
    "name": "FAQ's with Image",
    "settings": [
      {
        "type": "text",
        "id": "custom_class",
        "label": "Custom Class"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Left Image"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Heading"
      },
      {
        "type": "richtext",
        "id": "content",
        "label": "Content"
      },
      {
        "type": "color",
        "id": "faqs_background",
        "label": "Faq's Blocks Background",
        "default": "#AC2E2F"
      },
      {
        "type": "color",
        "id": "faqs_text_color",
        "label": "Faq's Text Color",
        "default": "#ffffff"
      },
      {
        "type": "range",
        "id": "faqs_page_width",
        "min": 1000,
        "max": 2000,
        "step": 10,
        "default": 1200,
        "unit": "px",
        "label": "Section Width"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
      }
    ],
    "blocks": [
      {
        "type": "question",
        "name": "Question",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Question",
            "default": "Any Question?"
          },
          {
            "type": "richtext",
            "id": "answer",
            "label": "Answer",
            "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Fusce ullamcorper nec diam sit amet consectetur. Ut ex lacus, laoreet ac sem maximus, ornare dictum nisl. Donec vitae lacus interdum, laoreet quam sed, fermentum purus. Fusce vehicula ligula dignissim libero</p>"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "FAQ's with Image",
        "blocks": []
      }
    ]
  }
{% endschema %}

