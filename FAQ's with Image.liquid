{% javascript %}
$(function () {
  $(".shopify_explorer_faq__item:first-of-type .shopify_explorer_faq__answer").css("display", "block");
  $(".shopify_explorer_faq__item:first-of-type .shopify_explorer_faq__question").addClass("open");
 
  $(".shopify_explorer_faq__question").click(function () {
    $(".open").not(this).removeClass("open").next().slideUp(300);
    $(this).toggleClass("open").next().slideToggle(300);
  });
});
{% endjavascript %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="custom-faq-section section-{{ section.id }}-padding">
  <div class="{% if section.settings.custom_class != blank %}{{ section.settings.custom_class }} {% endif %}page-width">
    <div class="faqs_page_width">
      {% if section.settings.image != blank %}
        <div class="faq-image-left">
          <img src="{{ section.settings.image | image_url: width: 900 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
        </div>
      {% endif %}
      <div class="faq-content-right">
        <div class="custom-section-title section_heading_div section_heading_center">
          {%- if section.settings.title != blank -%}
