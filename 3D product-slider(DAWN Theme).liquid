{{ 'component-price.css' | asset_url | stylesheet_tag }}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.css">

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-slider-wrapper-{{ section.id }} {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .custom-slider-wrapper-{{ section.id }} {
      padding-left: 5rem;
      padding-right: 5rem;
    }
  }

  /* Custom Slider Container Styles */
  .carousel-slider-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    padding: 2rem 0;
  }

  .carousel-slider-{{ section.id }} .swiper-wrapper {
    display: flex;
    align-items: center;
    /* Adjust based on typical Dawn product card height */
    min-height: 450px;
  }

  .carousel-slider-{{ section.id }} .swiper-slide {
    width: clamp(260px, 40vw, 400px);
    box-sizing: border-box;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: transform 0.3s ease;
    border-radius: var(--card-corner-radius, 1.2rem);
    background: transparent;
  }

  /* Active/Inactive slide aesthetic */
  .carousel-slider-{{ section.id }} .swiper-slide {
    background: rgba(var(--color-foreground), 0.05);
  }

  .carousel-slider-{{ section.id }} .swiper-slide.swiper-slide-next,
  .carousel-slider-{{ section.id }} .swiper-slide.swiper-slide-prev {
      background: rgba(var(--color-foreground), 0.08);
  }

  .carousel-slider-{{ section.id }} .swiper-slide.swiper-slide-active {
      background: rgb(var(--color-background));
      box-shadow: 0 0 25px 2px rgba(var(--color-foreground), 0.1);
  }

  /* Force the dawn card to take up the full slide height and look clean */
  .carousel-slider-{{ section.id }} .card-wrapper {
    width: 100%;
    height: 100%;
  }

  .carousel-slider-{{ section.id }} .card {
    background: transparent;
    border: none;
  }

  {%- if section.settings.show_navigation -%}
  .carousel-slider-{{ section.id }} .swiper-button-next,
  .carousel-slider-{{ section.id }} .swiper-button-prev {
    color: rgb(var(--color-button-text));
    background-color: rgba(var(--color-button), var(--alpha-button-background));
    width: 4.4rem;
    height: 4.4rem;
    border-radius: 50%;
    box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .carousel-slider-{{ section.id }} .swiper-button-next:after,
  .carousel-slider-{{ section.id }} .swiper-button-prev:after {
    font-size: 1.6rem;
    font-weight: bold;
  }
  .carousel-slider-{{ section.id }} .swiper-button-next:hover,
  .carousel-slider-{{ section.id }} .swiper-button-prev:hover {
    transform: scale(1.05);
  }
  {%- endif -%}
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div class="custom-slider-wrapper-{{ section.id }} section-{{ section.id }}-padding">
    {%- if section.settings.title != blank -%}
      <h2 class="custom-section-title title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.title }}
      </h2>
    {%- endif -%}

    <div class="carousel-slider-{{ section.id }} swiper">
      <div class="swiper-wrapper">
        {%- assign collection = section.settings.collection -%}
        {%- assign limit = section.settings.products_to_show -%}

        {%- for product in collection.products limit: limit -%}
          <div class="swiper-slide">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              image_shape: section.settings.image_shape,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              show_quick_add: section.settings.enable_quick_add,
              section_id: section.id
            %}
          </div>
        {%- else -%}
          {%- for i in (1..limit) -%}
            <div class="swiper-slide">
              {%- assign placeholder_image = 'product-' | append: i -%}
              {% render 'card-product',
                show_vendor: section.settings.show_vendor,
                placeholder_image: placeholder_image
              %}
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_navigation -%}
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
      {%- endif -%}
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper(".carousel-slider-{{ section.id }}", {
        grabCursor: true,
        watchSlidesProgress: true,
        loop: true,
        slidesPerView: "auto",
        centeredSlides: true,
        spaceBetween: 20,
        initialSlide: 0,
        {%- if section.settings.enable_autoplay -%}
        autoplay: {
            delay: {{ section.settings.autoplay_speed | times: 1000 }},
            disableOnInteraction: false,
        },
        {%- endif -%}
        {%- if section.settings.show_navigation -%}
        navigation: {
          nextEl: '.carousel-slider-{{ section.id }} .swiper-button-next',
          prevEl: '.carousel-slider-{{ section.id }} .swiper-button-prev',
        },
        {%- endif -%}
        on: {
            progress(e) {
                const t = e.slides.length;
                for (let r = 0; r < e.slides.length; r += 1) {
                    const o = e.slides[r],
                        s = e.slides[r].progress,
                        i = Math.abs(s);
                    let n = 1;
                    if (i > 1) {
                      n = 0.3 * (i - 1) + 1;
                    }
                    
                    const l = o.querySelectorAll(".card-wrapper"),
                        a = s * n * 80 + "%",
                        c = 1 - 0.2 * i,
                        d = t - Math.abs(Math.round(s));
                        
                    o.style.transform = `translateX(${a}) scale(${c})`;
                    o.style.zIndex = d.toString();
                    o.style.opacity = (i > 3 ? 0 : 1).toString();
                    
                    l.forEach((el) => {
                        el.style.opacity = (1 - i / 3).toString();
                    });
                }
            },
            setTransition(e, t) {
                for (let r = 0; r < e.slides.length; r += 1) {
                    const o = e.slides[r],
                        s = o.querySelectorAll(".card-wrapper");
                        
                    o.style.transitionDuration = `${t}ms`;
                    s.forEach((el) => {
                        el.style.transitionDuration = `${t}ms`;
                    });
                }
            }
        }
    });
  });
</script>

{% schema %}
{
  "name": "3D Product Slider",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Featured Collection",
      "label": "Section Title"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading Size"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 5,
      "label": "Maximum products to show"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable auto-rotate",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "header",
      "content": "Product Card Styling"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to image"
        },
        {
          "value": "portrait",
          "label": "Portrait"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "adapt",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating",
      "info": "To display a rating, add a product rating app."
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "default": false,
      "label": "Enable quick add button"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "3D Product Slider",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}


